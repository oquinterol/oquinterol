{
	"name": "oquinterol",
	"type": "module",
	"version": "0.0.1",
	"packageManager": "pnpm@11.2.2",
	"scripts": {
		"dev": "astro check --watch & astro dev",
		"start": "astro dev",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"astro": "astro",
		"format": "prettier --write \"**/*.{js,jsx,ts,tsx,md,mdx,svelte,astro}\"",
		"format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,md,mdx,svelte,astro}\"",
		"lint": "eslint --fix \"src/**/*.{js,ts,jsx,tsx,svelte,astro}\"",
		"lint:check": "eslint \"src/**/*.{js,ts,jsx,tsx,svelte,astro}\""
	},
	"dependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/mdx": "^5.0.6",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.2",
		"astro": "^6.3.7",
		"astro-expressive-code": "^0.42.0",
		"autoprefixer": "^10.4.23",
		"clsx": "^2.1.1",
		"mdast-util-to-string": "^4.0.0",
		"reading-time": "^1.5.0",
		"rehype-external-links": "^3.0.0",
		"remark-unwrap-images": "^4.0.1",
		"sharp": "^0.34.5",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^3.4.19",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@tailwindcss/aspect-ratio": "^0.4.2",
		"@tailwindcss/typography": "^0.5.19",
		"@typescript-eslint/parser": "^8.59.4",
		"eslint": "^8.57.1",
		"eslint-plugin-astro": "^1.7.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"prettier": "^3.8.3",
		"prettier-config-standard": "^7.0.0",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-tailwindcss": "^0.8.0"
