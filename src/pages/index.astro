---
import PageLayout from '../layouts/BaseLayout.astro'
import Section from '../components/Section.astro'
import Card from '../components/Card.astro'
import Label from '../components/Label.astro'
import SkillLayout from '../components/SkillLayout.astro'

import { Image } from 'astro:assets'
import astro from '../assets/Perfil.png'

const languages = ['Español (Nativo)', 'Inglés (Intermedio)']
const bioinformatics = [
	'BWA/Bowtie2',
	'BLAST+',
	'GATK',
	'RNA-seq',
	'GBS',
	'de novo assembly',
	'Trimmomatic',
	'Trinity',
	'FastQC/MultiQC',
	'BUSCO',
	'BlobToolKit',
	'AUGUSTUS'
]
const systemsBiology = [
	'COBRApy',
	'COBRA Toolbox',
	'SBML',
	'KEGG API',
	'MEMOTE',
	'FBA/FVA',
	'Gap-filling'
]
const programming = [
	'Python (pandas, NumPy, SciPy)',
	'R (tidyverse, ggplot2)',
	'Bash',
	'SQL/SQLite',
	'AWK',
	'MATLAB',
	'Streamlit',
	'Jupyter'
]
const systems = [
	'Linux (Debian/Ubuntu/Arch)',
	'Docker/Compose',
	'SLURM',
	'Environment Modules',
	'SSH/Administración de clúster'
]
const workflows = [
	'Git/GitHub',
	'GitHub Actions (CI/CD)',
	'Make',
	'Snakemake',
	'Nextflow',
	'Conda',
	'pyenv',
	'LaTeX/Markdown'
]
---

<PageLayout meta={{ title: 'CV' }}>
	<div class='flex w-full flex-col gap-y-10'>
		<section class='flex flex-col items-center gap-y-7'>
			<Image src={astro} alt='profile photo' class='h-auto w-28 rounded-full' loading='eager' />

			<div class='flex flex-col items-center gap-y-4'>
				<h1 class='text-3xl font-bold'>Oscar A. Quintero Lopéz</h1>
				<div class='flex gap-x-3'>
					<a
						target='_blank'
						rel='noopener noreferrer'
						href='https://github.com/oquinterol/CurriculumVitae/releases/latest/download/cv_spanish.pdf'
						class='flex flex-row items-center gap-x-3 rounded-3xl border border-input px-4 py-2 text-sm shadow-sm transition-all hover:shadow-md'
					>
						<span class='relative flex items-center justify-center'>
							<span
								class='absolute inline-flex h-2 w-2 animate-ping rounded-full border border-green-400 bg-green-400 opacity-75'
							></span>
							<span class='relative inline-flex h-2 w-2 rounded-full bg-green-400'></span>
						</span>

						<p class='font-medium'>CV Español</p>
					</a>
					<a
						target='_blank'
						rel='noopener noreferrer'
						href='https://github.com/oquinterol/CurriculumVitae/releases/latest/download/cv_english.pdf'
						class='flex flex-row items-center gap-x-3 rounded-3xl border border-input px-4 py-2 text-sm shadow-sm transition-all hover:shadow-md'
					>
						<span class='relative flex items-center justify-center'>
							<span
								class='absolute inline-flex h-2 w-2 animate-ping rounded-full border border-green-400 bg-green-400 opacity-75'
							></span>
							<span class='relative inline-flex h-2 w-2 rounded-full bg-green-400'></span>
						</span>

						<p class='font-medium'>CV English</p>
					</a>
				</div>
				<div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
					<Label title='Bioinformático'>
						<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' class='h-5 w-5' slot='icon'
							><path
								fill='currentColor'
								d='M4.615 20q-.69 0-1.152-.462Q3 19.075 3 18.385v-9.77q0-.69.463-1.152Q3.925 7 4.615 7H9V5.615q0-.69.463-1.152Q9.925 4 10.615 4h2.77q.69 0 1.153.463q.462.462.462 1.152V7h4.385q.69 0 1.152.463q.463.462.463 1.152v9.77q0 .69-.462 1.152q-.463.463-1.153.463zm0-1h14.77q.23 0 .423-.192q.192-.193.192-.423v-9.77q0-.23-.192-.423Q19.615 8 19.385 8H4.615q-.23 0-.423.192Q4 8.385 4 8.615v9.77q0 .23.192.423q.193.192.423.192M10 7h4V5.615q0-.23-.192-.423Q13.615 5 13.385 5h-2.77q-.23 0-.423.192q-.192.193-.192.423zM4 19V8z'
							></path></svg
						>
					</Label>
					<Label title='Bogotá D.C., Colombia'>
						<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' class='h-5 w-5' slot='icon'
							><path
								fill='currentColor'
								d='M12.003 11.73q.668 0 1.14-.475q.472-.475.472-1.143t-.475-1.14q-.476-.472-1.143-.472t-1.14.476q-.472.475-.472 1.143t.475 1.14q.476.472 1.143.472M12 19.677q2.82-2.454 4.458-4.991q1.638-2.538 1.638-4.39q0-2.744-1.737-4.53T12 3.981q-2.621 0-4.359 1.785t-1.737 4.53q0 1.852 1.638 4.39q1.639 2.537 4.458 4.99m0 1.343q-3.525-3.117-5.31-5.814q-1.786-2.697-1.786-4.909q0-3.173 2.066-5.234Q9.037 3 12 3t5.03 2.062q2.066 2.061 2.066 5.234q0 2.212-1.785 4.909q-1.786 2.697-5.311 5.814m0-10.904'
							></path></svg
						>
					</Label>
					<Label
						title='Conéctate en LinkedIn'
						as='a'
						href='https://www.linkedin.com/in/oquinterol/'
						target='_blank'
						rel='noopener noreferrer'
					>
						<svg
							xmlns='http://www.w3.org/2000/svg'
							viewBox='0 0 16 16'
							slot='icon'
							class='h-5 w-5 text-foreground/75'
							><path
								fill='currentColor'
								d='M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248c-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586c.173-.431.568-.878 1.232-.878c.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252c-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z'
							></path></svg
						>
					</Label>
				</div>
			</div>
		</section>

		<Section title='Sobre mí'>
			<p class='text-muted-foreground'>
				Como bioinformático y licenciado en Biología, mi pasión radica en el cruce de la tecnología
				y la ciencia de la vida, particularmente en el desarrollo y aplicación de modelos genómicos
				para la mejora de cultivos. Actualmente, me encuentro ampliando mis conocimientos mediante
				una maestría en Bioinformática en la Universidad Nacional de Colombia. Mi experiencia
				incluye el desarrollo de pipelines bioinformáticos para análisis de RNA-Seq. Me enorgullece
				contribuir a la investigación y educación en bioinformática, enfocándome en aplicar
				soluciones tecnológicas para abordar desafíos complejos en biología.
			</p>
		</Section>

		<Section title='Educación'>
			<Card
				heading='Master en Bioinformática'
				subheading='Universidad Nacional de Colombia'
				imagePath='/src/assets/blank.png'
				altText='Maestría en Bioinformática'
				imageClass='h-12 w-auto md:-left-16'
			/>
			<Card
				heading='Licenciado en Biología'
				subheading='Universidad Distrital Francisco José de Caldas'
				imagePath='/src/assets/blank.png'
				altText='Licenciado en Biologia'
				imageClass='h-12 w-auto md:-left-16'
			/>
		</Section>

		<Section title='Habilidades'>
			<SkillLayout title='Idiomas' skills={languages} />
			<SkillLayout title='Bioinformática' skills={bioinformatics} />
			<SkillLayout title='Biología de Sistemas / GEMs' skills={systemsBiology} />
			<SkillLayout title='Programación y Análisis' skills={programming} />
			<SkillLayout title='Sistemas y HPC' skills={systems} />
			<SkillLayout title='Reproducibilidad y Flujos de Trabajo' skills={workflows} />
		</Section>
	</div>
	<a
		href='mailto:oquinterol@unal.edu.co'
		class='mt-16 flex flex-row items-center gap-x-3 rounded-3xl border border-input px-4 py-2 text-sm shadow-sm transition-all hover:shadow-md'
	>
		<span class='relative flex items-center justify-center'>
			<span
				class='absolute inline-flex h-2 w-2 animate-ping rounded-full border border-green-400 bg-green-400 opacity-75'
			></span>
			<span class='relative inline-flex h-2 w-2 rounded-full bg-green-400'></span>
		</span>

		<p class='font-medium'>Contácteme</p>
	</a>
</PageLayout>
