---
import { Image } from 'astro:assets'
import blankImage from '@/assets/blank.png'
import type { ImageMetadata } from 'astro'
import { cn } from '@/utils'

const {
	as: Tag = 'div',
	class: className,
	href,
	heading,
	subheading,
	date,
	imagePath,
	altText,
	imageClass
} = Astro.props
const images: Record<string, ImageMetadata> = {
	'/src/assets/blank.png': blankImage
}

if (!images[imagePath]) throw new Error(`"${imagePath}" is not configured in Card.astro`)
---

<Tag
	class={cn(
		className,
		'relative rounded-2xl border border-border bg-primary-foreground px-5 py-3',
		href && 'transition-all hover:border-foreground/25 hover:shadow-sm'
	)}
	href={href}
	target={href ? '_blank' : undefined}
	rel={href ? 'noopener noreferrer' : undefined}
>
	<Image
		src={images[imagePath]}
		alt={altText}
		class={cn('mb-3 md:absolute md:mb-0', imageClass)}
		loading='eager'
	/>
	<div class='flex flex-col gap-y-1.5'>
		<div class='flex flex-col gap-y-0.5'>
			<h1 class='text-lg font-medium'>{heading}</h1>
			{subheading && <h2 class='text-muted-foreground'>{subheading}</h2>}
			{date && <h2 class='text-muted-foreground'>{date}</h2>}
		</div>
		<slot />
	</div>
</Tag>
